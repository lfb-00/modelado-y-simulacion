@page
@model IndexModel
@{
    ViewData["Title"] = "Modelado y simulación";
}

@functions {
    static Microsoft.AspNetCore.Html.HtmlString SciLatex(double? value)
    {
        if (value == null) return new Microsoft.AspNetCore.Html.HtmlString("-");
        var s = value.Value.ToString("E2");
        var parts = s.Split('E');
        var mantissa = parts[0];
        var exp = int.Parse(parts[1]).ToString();
        var latex = mantissa + " \\times 10^{" + exp + "}";
        return new Microsoft.AspNetCore.Html.HtmlString(
            $"<span class=\"sci-katex\" data-latex=\"{latex}\"></span>");
    }
}

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-zoom@2.1.0/dist/chartjs-plugin-zoom.min.js"></script>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css">
<script src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/contrib/auto-render.min.js"></script>

<style>
    :root {
        color-scheme: dark;
    }

    body {
        background-color: #1a1a1a;
        color: #e0e0e0;
    }

    .container {
        background-color: #1a1a1a;
    }

    .card {
        background-color: #2a2a2a;
        border-color: #3a3a3a;
        color: #e0e0e0;
    }

    .form-control, .form-select {
        background-color: #2a2a2a;
        color: #e0e0e0;
        border-color: #3a3a3a;
    }

    .form-control:focus, .form-select:focus {
        background-color: #2a2a2a;
        color: #e0e0e0;
        border-color: #4a7c9e;
        box-shadow: 0 0 0 0.25rem rgba(74, 124, 158, 0.25);
    }

    .form-text {
        color: #a0a0a0;
    }

    .form-label {
        color: #e0e0e0;
    }

    .btn-primary {
        background-color: #0d6efd;
        border-color: #0d6efd;
    }

    .btn-primary:hover {
        background-color: #0b5ed7;
        border-color: #0a58ca;
    }

    .btn-outline-secondary {
        color: #6c757d;
        border-color: #6c757d;
    }

    .btn-outline-secondary:hover {
        background-color: #6c757d;
        color: #fff;
    }

    .table {
        color: #e0e0e0;
        border-color: #3a3a3a;
    }

    .table-striped > tbody > tr:nth-of-type(odd) {
        background-color: #252525;
    }

    .table thead {
        border-color: #3a3a3a;
    }

    .table-bordered {
        border-color: #3a3a3a;
    }

    .table-bordered > thead > tr > th,
    .table-bordered > tbody > tr > td {
        border-color: #3a3a3a;
    }

    .text-muted {
        color: #a0a0a0 !important;
    }

    h1, h5, p {
        color: #e0e0e0;
    }

    /* Estilos para KaTeX */
    .katex {
        color: #e0e0e0;
    }

    #resultFunctionLatex {
        font-family: 'Times New Roman', serif;
        color: #e0e0e0;
    }
</style>

<div class="container mt-4">
    <h1 class="mb-3">Simulación numérica en .NET</h1>
    <p>Calcula raíces usando una función ingresada por el usuario.</p>

    <form method="post">
        <div class="mb-3">
            <label asp-for="SelectedAlgorithm" class="form-label">Método</label>
            <select asp-for="SelectedAlgorithm" class="form-select">
                <option value="bisection">Bisección</option>
                <option value="newton">Newton-Raphson</option>
                <option value="fixed-point">Punto fijo</option>
                <option value="fixed-point-aitken">Punto fijo + Aitken (Δ²)</option>
            </select>
        </div>

        <div class="mb-3">
            <label asp-for="Function" class="form-label" id="functionLabel">Función</label>
            <input asp-for="Function" class="form-control" />
            <div class="form-text" id="functionHelpText">Ingrese la función en términos de x. Para punto fijo use g(x), para otros métodos use f(x).</div>
            <div class="form-text mt-2">
                <strong>Símbolos y funciones admitidas:</strong>
                <span> x, +, -, *, /, ^, paréntesis (), constantes pi y e, funciones sin(x), cos(x), tan(x), exp(x), log(x), ln(x), sqrt(x), abs(x), pow(a,b).</span>
            </div>
            <div class="form-text">
                <strong>Ejemplos:</strong>
                <span>sqrt(x) + log(x), sin(x) - x/2, x^3 - 4*x + 1, exp(-x) - x, abs(x-2), pow(x,2) - 9, cos(x) - x, ln(x) + 2.</span>
            </div>
        </div>

        <div class="row g-3" id="bisectionInputs">
            <div class="col-md-6">
                <label asp-for="A" class="form-label">a</label>
                <input asp-for="A" class="form-control" />
            </div>
            <div class="col-md-6">
                <label asp-for="B" class="form-label">b</label>
                <input asp-for="B" class="form-control" />
            </div>
        </div>

        <div class="row g-3 mt-2" id="x0Input">
            <div class="col-md-6">
                <label asp-for="X0" class="form-label">x₀</label>
                <input asp-for="X0" class="form-control" />
            </div>
        </div>

        <div class="row g-3 mt-2">
            <div class="col-md-6">
                <label asp-for="Tolerance" class="form-label">Tolerancia</label>
                <input asp-for="Tolerance" class="form-control" />
            </div>
            <div class="col-md-6">
                <label asp-for="MaxIterations" class="form-label">Máximo de iteraciones</label>
                <input asp-for="MaxIterations" class="form-control" />
            </div>
        </div>

        <button type="submit" class="btn btn-primary mt-3">Calcular</button>
    </form>

    <div class="card mt-4">
        <div class="card-body">
            <h5 class="card-title mb-3">
                <a data-bs-toggle="collapse" href="#metodosLeyenda" role="button" aria-expanded="false" aria-controls="metodosLeyenda" style="text-decoration: none; color: #e0e0e0;">
                    Sobre los métodos ▾
                </a>
            </h5>
            <div class="collapse" id="metodosLeyenda">
                <div class="row g-3">
                    <div class="col-md-6">
                        <h6>Bisección</h6>
                        <ul class="small">
                            <li>Convergencia lineal, siempre converge si hay cambio de signo en [a, b].</li>
                            <li>No requiere derivada ni función iterativa.</li>
                            <li>Es el método más robusto pero más lento.</li>
                        </ul>
                    </div>
                    <div class="col-md-6">
                        <h6>Newton-Raphson</h6>
                        <ul class="small">
                            <li>Convergencia cuadrática cerca de la raíz.</li>
                            <li>Llega muy rápido a una aproximación muy precisa.</li>
                            <li>Requiere calcular la derivada f'(x).</li>
                            <li>Suele ser más eficiente si la derivada es fácil de obtener.</li>
                        </ul>
                    </div>
                    <div class="col-md-6">
                        <h6>Punto fijo</h6>
                        <ul class="small">
                            <li>Convergencia lineal, depende de que |g'(x)| &lt; 1 cerca de la raíz.</li>
                            <li>No requiere derivada explícita.</li>
                            <li>Requiere reformular f(x) = 0 como x = g(x).</li>
                        </ul>
                    </div>
                    <div class="col-md-6">
                        <h6>Punto fijo + Aitken (Δ²)</h6>
                        <ul class="small">
                            <li>Acelera mucho la convergencia del punto fijo.</li>
                            <li>No requiere derivada explícita.</li>
                            <li>Puede ser más simple si ya tenés una función iterativa g(x).</li>
                            <li>Newton resulta más directo y preciso para tolerancias chicas.</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.ResultMessage))
    {
        <div class="card mt-4">
            <div class="card-body">
                <h5 class="card-title">Resultado</h5>
                <div class="mb-3">
                    <strong>Función utilizada:</strong>
                    <div id="resultFunctionLatex" class="border rounded p-2 mt-2" style="font-size: 1.2em; background-color: #2a2a2a; border-color: #3a3a3a;"></div>
                    <div class="mt-2">
                        <strong>LaTeX sin renderizar:</strong>
                        <div id="resultFunctionLatexRaw" class="border rounded p-2 mt-2" style="font-family: Consolas, 'Courier New', monospace; background-color: #222; border-color: #3a3a3a; white-space: pre-wrap;"></div>
                    </div>
                </div>
                @if (Model.SelectedAlgorithm == "newton")
                {
                    <div class="mb-2">
                        <strong>Fórmula:</strong>
                        <span id="newtonFormulaKatex"></span>
                    </div>
                }
                <p class="card-text">@Model.ResultMessage</p>
                @if (!string.IsNullOrEmpty(Model.SummaryMessage))
                {
                    <p class="card-text" id="summaryMessage"><strong>@Model.SummaryMessage</strong></p>
                }
                @if (!string.IsNullOrEmpty(Model.ConvergenceComment))
                {
                    <p class="card-text"><strong>@Model.ConvergenceComment</strong></p>
                }
            </div>
        </div>

        @if (Model.ChartXValues?.Count > 0)
        {
            <div class="card mt-4">
                <div class="card-body">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px;">
                        <h5 class="card-title" style="margin: 0;">Gráfico de la función (Enfocado)</h5>
                        <button type="button" class="btn btn-sm btn-outline-secondary" id="resetZoomBtn">Resetear Zoom</button>
                    </div>
                    <small class="text-muted">Rueda del ratón: zoom | Ctrl + Click: desplazamiento</small>
                    <div style="position: relative; width: 100%; height: 400px; margin-top: 10px;">
                        <canvas id="functionChart"></canvas>
                    </div>
                </div>
            </div>

            @if (Model.OverviewChartXValues?.Count > 0)
            {
                <div class="card mt-4">
                    <div class="card-body">
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px;">
                            <h5 class="card-title" style="margin: 0;">Gráfico de la función (Vista General)</h5>
                            <button type="button" class="btn btn-sm btn-outline-secondary" id="resetOverviewZoomBtn">Resetear Zoom</button>
                        </div>
                        <small class="text-muted">Rueda del ratón: zoom | Ctrl + Click: desplazamiento</small>
                        <div style="position: relative; width: 100%; height: 400px; margin-top: 10px;">
                            <canvas id="overviewChart"></canvas>
                        </div>
                    </div>
                </div>
            }
        }

        @if (Model.IterationNumbers?.Count > 0)
        {
            <div class="card mt-4">
                <div class="card-body">
                    <h5 class="card-title">Análisis de convergencia</h5>
                    <small class="text-muted">Estos gráficos muestran cómo evoluciona la aproximación y cómo cae el error por iteración.</small>
                    <div class="row g-4 mt-1">
                        <div class="col-lg-6">
                            <h6>Estimación por iteración</h6>
                            <div style="position: relative; width: 100%; height: 320px;">
                                <canvas id="iterationEstimateChart"></canvas>
                            </div>
                        </div>
                        <div class="col-lg-6">
                            <h6>Error absoluto, relativo y residual (escala log)</h6>
                            <div style="position: relative; width: 100%; height: 320px;">
                                <canvas id="iterationErrorChart"></canvas>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    }

    @if (Model.Steps?.Count > 0)
    {
        <div class="card mt-3">
            <div class="card-body">
                <h5 class="card-title">Pasos</h5>
                <div class="table-responsive">
                    <table class="table table-striped table-bordered mb-0">
                        <thead>
                            <tr>
                                @switch (Model.SelectedAlgorithm)
                                {
                                    case "bisection":
                                        <th>Iteración</th>
                                        <th>Extremo izq.</th>
                                        <th>Extremo der.</th>
                                        <th>Punto medio</th>
                                        <th>f en a</th>
                                        <th>f en b</th>
                                        <th>f en c</th>
                                        <th>Err. absoluto</th>
                                        <th>Err. relativo</th>
                                        break;
                                    case "newton":
                                        <th>Iteración</th>
                                        <th>Valor actual</th>
                                        <th>Función</th>
                                        <th>Derivada</th>
                                        <th>Siguiente valor</th>
                                        <th>Err. absoluto</th>
                                        <th>Err. relativo</th>
                                        <th>Residuo</th>
                                        break;
                                    case "fixed-point":
                                        <th>Iteración</th>
                                        <th>Valor actual</th>
                                        <th>Punto fijo</th>
                                        <th>Err. absoluto</th>
                                        <th>Err. relativo</th>
                                        <th>Residuo</th>
                                        break;
                                    case "fixed-point-aitken":
                                        <th>Iteración</th>
                                        <th>Valor actual</th>
                                        <th>Punto fijo</th>
                                        <th>Doble aplicación</th>
                                        <th>Aceleración de Aitken</th>
                                        <th>Err. absoluto</th>
                                        <th>Err. relativo</th>
                                        <th>Residuo</th>
                                        break;
                                }
                            </tr>
                            <tr>
                                @switch (Model.SelectedAlgorithm)
                                {
                                    case "bisection":
                                        <th><span class="header-katex" data-latex="n"></span></th>
                                        <th><span class="header-katex" data-latex="a_n"></span></th>
                                        <th><span class="header-katex" data-latex="b_n"></span></th>
                                        <th><span class="header-katex" data-latex="c_n = \frac{a_n + b_n}{2}"></span></th>
                                        <th><span class="header-katex" data-latex="f(a_n)"></span></th>
                                        <th><span class="header-katex" data-latex="f(b_n)"></span></th>
                                        <th><span class="header-katex" data-latex="f(c_n)"></span></th>
                                        <th><span class="header-katex" data-latex="\frac{b_n - a_n}{2}"></span></th>
                                        <th><span class="header-katex" data-latex="\frac{|c_n - c_{n-1}|}{|c_n|}"></span></th>
                                        break;
                                    case "newton":
                                        <th><span class="header-katex" data-latex="n"></span></th>
                                        <th><span class="header-katex" data-latex="x_n"></span></th>
                                        <th><span class="header-katex" data-latex="f(x_n)"></span></th>
                                        <th><span class="header-katex" data-latex="f'(x_n)"></span></th>
                                        <th><span class="header-katex" data-latex="x_{n+1} = x_n - \frac{f(x_n)}{f'(x_n)}"></span></th>
                                        <th><span class="header-katex" data-latex="|x_{n+1} - x_n|"></span></th>
                                        <th><span class="header-katex" data-latex="\frac{|x_{n+1} - x_n|}{|x_{n+1}|}"></span></th>
                                        <th><span class="header-katex" data-latex="|f(x_n)|"></span></th>
                                        break;
                                    case "fixed-point":
                                        <th><span class="header-katex" data-latex="n"></span></th>
                                        <th><span class="header-katex" data-latex="x_n"></span></th>
                                        <th><span class="header-katex" data-latex="x_{n+1} = g(x_n)"></span></th>
                                        <th><span class="header-katex" data-latex="|x_{n+1} - x_n|"></span></th>
                                        <th><span class="header-katex" data-latex="\frac{|x_{n+1} - x_n|}{|x_{n+1}|}"></span></th>
                                        <th><span class="header-katex" data-latex="|g(x_n) - x_n|"></span></th>
                                        break;
                                    case "fixed-point-aitken":
                                        <th><span class="header-katex" data-latex="n"></span></th>
                                        <th><span class="header-katex" data-latex="x_n"></span></th>
                                        <th><span class="header-katex" data-latex="x_{n+1} = g(x_n)"></span></th>
                                        <th><span class="header-katex" data-latex="x_{n+2} = g(x_{n+1})"></span></th>
                                        <th><span class="header-katex" data-latex="\hat{x}_n = x_n - \frac{(x_{n+1} - x_n)^2}{x_{n+2} - 2x_{n+1} + x_n}"></span></th>
                                        <th><span class="header-katex" data-latex="|\hat{x}_n - x_n|"></span></th>
                                        <th><span class="header-katex" data-latex="\frac{|\hat{x}_n - x_n|}{|\hat{x}_n|}"></span></th>
                                        <th><span class="header-katex" data-latex="|g(\hat{x}_n) - \hat{x}_n|"></span></th>
                                        break;
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var step in Model.Steps)
                            {
                                <tr>
                                    <td>@(Model.SelectedAlgorithm == "fixed-point-aitken" ? (step.Iteration - 1) : step.Iteration)</td>
                                    @switch (Model.SelectedAlgorithm)
                                    {
                                        case "bisection":
                                            <td>@(step.A?.ToString("F8") ?? "-")</td>
                                            <td>@(step.B?.ToString("F8") ?? "-")</td>
                                            <td>@(step.Mid?.ToString("F8") ?? "-")</td>
                                            <td>@(step.FA?.ToString("F8") ?? "-")</td>
                                            <td>@(step.FB?.ToString("F8") ?? "-")</td>
                                            <td>@(step.FC?.ToString("F8") ?? "-")</td>
                                            <td>@SciLatex(step.Error)</td>
                                            <td>@SciLatex(step.RelativeError)</td>
                                            break;
                                        case "newton":
                                            <td>@(step.X?.ToString("F8") ?? "-")</td>
                                            <td>@(step.FX?.ToString("F8") ?? "-")</td>
                                            <td>@(step.DFX?.ToString("F8") ?? "-")</td>
                                            <td>@(step.NextX?.ToString("F8") ?? "-")</td>
                                            <td>@SciLatex(step.Error)</td>
                                            <td>@(step.Iteration == 1 ? "N/A" : SciLatex(step.RelativeError))</td>
                                            <td>@SciLatex(step.Residual)</td>
                                            break;
                                        case "fixed-point":
                                            <td>@(step.X?.ToString("F8") ?? "-")</td>
                                            <td>@(step.G?.ToString("F8") ?? "-")</td>
                                            <td>@SciLatex(step.Error)</td>
                                            <td>@SciLatex(step.RelativeError)</td>
                                            <td>@SciLatex(step.Residual)</td>
                                            break;
                                        case "fixed-point-aitken":
                                            <td>@(step.X?.ToString("F8") ?? "-")</td>
                                            <td>@(step.G?.ToString("F8") ?? "-")</td>
                                            <td>@(step.GG?.ToString("F8") ?? "-")</td>
                                            <td>@(step.AitkenX?.ToString("F8") ?? "-")</td>
                                            <td>@SciLatex(step.Error)</td>
                                            <td>@SciLatex(step.RelativeError)</td>
                                            <td>@SciLatex(step.Residual)</td>
                                            break;
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    <script>
        function updateFormInputs() {
            const algorithm = document.getElementById('SelectedAlgorithm').value;
            const bisectionInputs = document.getElementById('bisectionInputs');
            const x0Input = document.getElementById('x0Input');
            const functionLabel = document.getElementById('functionLabel');
            const functionHelp = document.getElementById('functionHelpText');

            if (algorithm === 'bisection') {
                bisectionInputs.style.display = 'flex';
                x0Input.style.display = 'none';
                functionLabel.textContent = 'Función f(x)';
                functionHelp.textContent = 'Ingrese f(x). La bisección necesita un intervalo [a, b] con cambio de signo.';
            } else if (algorithm === 'newton') {
                bisectionInputs.style.display = 'none';
                x0Input.style.display = 'flex';
                functionLabel.textContent = 'Función f(x)';
                functionHelp.textContent = 'Ingrese f(x). Newton-Raphson usa x₀ como semilla inicial.';
            } else {
                bisectionInputs.style.display = 'none';
                x0Input.style.display = 'flex';
                functionLabel.textContent = 'Función g(x)';
                if (algorithm === 'fixed-point-aitken') {
                    functionHelp.textContent = 'Ingrese g(x). Aitken acelera xₙ₊₁ = g(xₙ) con Δ² para mejorar convergencia.';
                } else {
                    functionHelp.textContent = 'Ingrese g(x). El método de punto fijo itera xₙ₊₁ = g(xₙ).';
                }
            }
        }

        // Función para convertir expresión matemática a LaTeX
        function expressionToLatex(expr) {
            if (!expr || expr.trim() === '') {
                return '';
            }

            let latex = expr.trim();

            // Reemplazar operadores
            latex = latex.replace(/\*\*/g, '^'); // ** por ^
            latex = latex.replace(/\*/g, ' \\cdot '); // * por \cdot
            latex = latex.replace(/\//g, ' \\div '); // / por \div

            // Reemplazar funciones matemáticas
            latex = latex.replace(/sin\(/g, '\\sin(');
            latex = latex.replace(/cos\(/g, '\\cos(');
            latex = latex.replace(/tan\(/g, '\\tan(');
            latex = latex.replace(/exp\(/g, '\\exp(');
            latex = latex.replace(/log\(/g, '\\log(');
            latex = latex.replace(/ln\(/g, '\\ln(');
            latex = latex.replace(/sqrt\(/g, '\\sqrt{');
            latex = latex.replace(/abs\(/g, '\\left|');
            latex = latex.replace(/pow\(/g, ''); // pow(a,b) será manejado después

            // Reemplazar constantes
            latex = latex.replace(/\bpi\b/g, '\\pi');
            latex = latex.replace(/\be\b/g, 'e');

            // Manejar pow(a,b) -> a^b
            latex = latex.replace(/pow\s*\(\s*([^,]+)\s*,\s*([^)]+)\s*\)/g, '$1^{$2}');

            // Cerrar paréntesis para funciones que lo necesitan
            latex = latex.replace(/\\sqrt\{([^}]+)\)/g, '\\sqrt{$1}');
            latex = latex.replace(/\\left\|([^|]+)\)/g, '\\left|$1\\right|');

            // Agregar la variable x en modo matemático
            latex = latex.replace(/\bx\b/g, 'x');

            return latex;
        }

        // Función para renderizar LaTeX en los resultados
        function renderResultFunctionLatex() {
            const resultDiv = document.getElementById('resultFunctionLatex');
            const resultRawDiv = document.getElementById('resultFunctionLatexRaw');
            const functionInput = document.getElementById('Function');

            if (resultDiv && functionInput) {
                const expr = functionInput.value;
                const latexExpr = expressionToLatex(expr);

                if (resultRawDiv) {
                    resultRawDiv.textContent = latexExpr || '';
                }

                if (latexExpr) {
                    try {
                        katex.render(latexExpr, resultDiv, {
                            throwOnError: false,
                            displayMode: false
                        });
                    } catch (error) {
                        resultDiv.textContent = 'Error al renderizar: ' + expr;
                    }
                } else {
                    resultDiv.textContent = '';
                }
            }
        }

        document.addEventListener('DOMContentLoaded', function () {
            const algorithmSelect = document.getElementById('SelectedAlgorithm');
            if (algorithmSelect) {
                algorithmSelect.addEventListener('change', updateFormInputs);
                updateFormInputs();
            }

            // Renderizar LaTeX en resultados si hay resultados
            if (@(!string.IsNullOrEmpty(Model.ResultMessage) ? "true" : "false")) {
                renderResultFunctionLatex();
            }

            // Renderizar fórmula de Newton-Raphson
            var newtonFormulaEl = document.getElementById('newtonFormulaKatex');
            if (newtonFormulaEl) {
                katex.render('x_{n+1} = x_n - \\frac{f(x_n)}{f\'(x_n)}', newtonFormulaEl, { throwOnError: false, displayMode: false });
            }

            // Renderizar fórmulas LaTeX en headers de tabla
            document.querySelectorAll('.header-katex').forEach(function(el) {
                var latex = el.getAttribute('data-latex');
                if (latex) {
                    katex.render(latex, el, { throwOnError: false, displayMode: false });
                }
            });

            // Renderizar notación científica en celdas de tabla
            document.querySelectorAll('.sci-katex').forEach(function(el) {
                var latex = el.getAttribute('data-latex');
                if (latex) {
                    katex.render(latex, el, { throwOnError: false, displayMode: false });
                }
            });

            // Renderizar LaTeX en el resumen (criterio de corte)
            var summaryEl = document.getElementById('summaryMessage');
            if (summaryEl) {
                renderMathInElement(summaryEl, {
                    delimiters: [
                        {left: "\\(", right: "\\)", display: false}
                    ],
                    throwOnError: false
                });
            }

            // Renderizar gráfico si hay datos
            const chartXValues = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ChartXValues ?? new List<double>()));
            const chartYValues = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ChartYValues ?? new List<double>()));
            const rootX = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.RootX));
            const rootY = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.RootY));
            const selectedAlgorithm = '@Model.SelectedAlgorithm';

            if (chartXValues && chartXValues.length > 0) {
                const canvas = document.getElementById('functionChart');
                if (canvas) {
                    const ctx = canvas.getContext('2d');
                    
                    // Calcular rango de X e Y con expansión
                    const xMin = Math.min(...chartXValues);
                    const xMax = Math.max(...chartXValues);
                    const yMin = Math.min(...chartYValues);
                    const yMax = Math.max(...chartYValues);
                    
                    const xRange = xMax - xMin || 1;
                    const yRange = yMax - yMin || 1;
                    const xPadding = xRange * 0.25;
                    const yPadding = yRange * 0.25;
                    
                    const datasets = [
                        {
                            label: selectedAlgorithm === 'fixed-point' || selectedAlgorithm === 'fixed-point-aitken' ? 'g(x)' : 'f(x)',
                            data: chartYValues,
                            borderColor: 'rgb(100, 200, 220)',
                            backgroundColor: 'transparent',
                            borderWidth: 2,
                            fill: false,
                            tension: 0.1,
                            pointRadius: 0,
                            pointHoverRadius: 5
                        }
                    ];

                    // Agregar punto de raíz si existe
                    if (rootX !== null && rootY !== null && !isNaN(parseFloat(rootX))) {
                        datasets.push({
                            label: 'Raíz encontrada',
                            data: [{x: parseFloat(rootX), y: parseFloat(rootY)}],
                            borderColor: 'rgb(255, 99, 132)',
                            backgroundColor: 'rgb(255, 99, 132)',
                            pointRadius: 8,
                            pointHoverRadius: 12,
                            showLine: false,
                            type: 'scatter'
                        });
                    }

                    const chart = new Chart(ctx, {
                        type: 'line',
                        data: {
                            labels: chartXValues,
                            datasets: datasets
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            interaction: {
                                intersect: false,
                                mode: 'index'
                            },
                            plugins: {
                                legend: {
                                    display: true,
                                    position: 'top'
                                },
                                filler: {
                                    propagate: true
                                },
                                zoom: {
                                    zoom: {
                                        wheel: {
                                            enabled: true,
                                            speed: 0.1,
                                            modifierKey: null
                                        },
                                        pinch: {
                                            enabled: true
                                        },
                                        mode: 'xy'
                                    },
                                    pan: {
                                        enabled: true,
                                        mode: 'xy',
                                        modifierKey: 'ctrl'
                                    },
                                    limits: {
                                        x: {min: 'original', max: 'original'},
                                        y: {min: 'original', max: 'original'}
                                    }
                                }
                            },
                            scales: {
                                x: {
                                    type: 'linear',
                                    position: 'bottom',
                                    min: xMin - xPadding,
                                    max: xMax + xPadding,
                                    title: {
                                        display: true,
                                        text: 'x',
                                        font: {
                                            size: 14
                                        }
                                    },
                                    grid: {
                                        drawBorder: true,
                                        color: function(context) {
                                            if (context.tick.value === 0) {
                                                return 'rgba(200, 200, 200, 0.8)';
                                            }
                                            return 'rgba(100, 100, 100, 0.2)';
                                        },
                                        lineWidth: function(context) {
                                            return context.tick.value === 0 ? 2.5 : 1;
                                        }
                                    },
                                    ticks: {
                                        padding: 10,
                                        autoSkip: true,
                                        maxRotation: 0
                                    }
                                },
                                y: {
                                    position: 'left',
                                    min: yMin - yPadding,
                                    max: yMax + yPadding,
                                    title: {
                                        display: true,
                                        text: selectedAlgorithm === 'fixed-point' || selectedAlgorithm === 'fixed-point-aitken' ? 'g(x)' : 'f(x)',
                                        font: {
                                            size: 14
                                        }
                                    },
                                    grid: {
                                        drawBorder: true,
                                        color: function(context) {
                                            if (context.tick.value === 0) {
                                                return 'rgba(200, 200, 200, 0.8)';
                                            }
                                            return 'rgba(100, 100, 100, 0.2)';
                                        },
                                        lineWidth: function(context) {
                                            return context.tick.value === 0 ? 2.5 : 1;
                                        }
                                    },
                                    ticks: {
                                        padding: 10,
                                        autoSkip: true
                                    }
                                }
                            }
                        }
                    });

                    // Agregar funcionalidad de reset de zoom
                    const resetZoomBtn = document.getElementById('resetZoomBtn');
                    if (resetZoomBtn) {
                        resetZoomBtn.addEventListener('click', function() {
                            chart.resetZoom();
                        });
                    }

                    // Guardar referencia global al chart
                    window.functionChart = chart;
                }
            }

            // Renderizar gráfico de visión general si hay datos
            const overviewChartXValues = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.OverviewChartXValues ?? new List<double>()));
            const overviewChartYValues = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.OverviewChartYValues ?? new List<double>()));

            if (overviewChartXValues && overviewChartXValues.length > 0) {
                const overviewCanvas = document.getElementById('overviewChart');
                if (overviewCanvas) {
                    const overviewCtx = overviewCanvas.getContext('2d');

                    const overviewDatasets = [
                        {
                            label: selectedAlgorithm === 'fixed-point' || selectedAlgorithm === 'fixed-point-aitken' ? 'g(x)' : 'f(x)',
                            data: overviewChartYValues,
                            borderColor: 'rgb(100, 200, 220)',
                            backgroundColor: 'transparent',
                            borderWidth: 2,
                            fill: false,
                            tension: 0.1,
                            pointRadius: 0,
                            pointHoverRadius: 5
                        }
                    ];

                    // Agregar punto de raíz si existe
                    if (rootX !== null && rootY !== null && !isNaN(parseFloat(rootX))) {
                        overviewDatasets.push({
                            label: 'Raíz encontrada',
                            data: [{x: parseFloat(rootX), y: parseFloat(rootY)}],
                            borderColor: 'rgb(255, 99, 132)',
                            backgroundColor: 'rgb(255, 99, 132)',
                            pointRadius: 8,
                            pointHoverRadius: 12,
                            showLine: false,
                            type: 'scatter'
                        });
                    }

                    const overviewChart = new Chart(overviewCtx, {
                        type: 'line',
                        data: {
                            labels: overviewChartXValues,
                            datasets: overviewDatasets
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            interaction: {
                                intersect: false,
                                mode: 'index'
                            },
                            plugins: {
                                legend: {
                                    display: true,
                                    position: 'top'
                                },
                                filler: {
                                    propagate: true
                                },
                                zoom: {
                                    zoom: {
                                        wheel: {
                                            enabled: true,
                                            speed: 0.1,
                                            modifierKey: null
                                        },
                                        pinch: {
                                            enabled: true
                                        },
                                        mode: 'xy'
                                    },
                                    pan: {
                                        enabled: true,
                                        mode: 'xy',
                                        modifierKey: 'ctrl'
                                    },
                                    limits: {
                                        x: {min: 'original', max: 'original'},
                                        y: {min: 'original', max: 'original'}
                                    }
                                }
                            },
                            scales: {
                                x: {
                                    type: 'linear',
                                    position: 'bottom',
                                    min: -30,
                                    max: 30,
                                    title: {
                                        display: true,
                                        text: 'x',
                                        font: {
                                            size: 14
                                        }
                                    },
                                    grid: {
                                        drawBorder: true,
                                        color: function(context) {
                                            if (context.tick.value === 0) {
                                                return 'rgba(200, 200, 200, 0.8)';
                                            }
                                            return 'rgba(100, 100, 100, 0.2)';
                                        },
                                        lineWidth: function(context) {
                                            return context.tick.value === 0 ? 2.5 : 1;
                                        }
                                    },
                                    ticks: {
                                        padding: 10,
                                        autoSkip: true,
                                        maxRotation: 0
                                    }
                                },
                                y: {
                                    position: 'left',
                                    min: -30,
                                    max: 30,
                                    title: {
                                        display: true,
                                        text: selectedAlgorithm === 'fixed-point' || selectedAlgorithm === 'fixed-point-aitken' ? 'g(x)' : 'f(x)',
                                        font: {
                                            size: 14
                                        }
                                    },
                                    grid: {
                                        drawBorder: true,
                                        color: function(context) {
                                            if (context.tick.value === 0) {
                                                return 'rgba(200, 200, 200, 0.8)';
                                            }
                                            return 'rgba(100, 100, 100, 0.2)';
                                        },
                                        lineWidth: function(context) {
                                            return context.tick.value === 0 ? 2.5 : 1;
                                        }
                                    },
                                    ticks: {
                                        padding: 10,
                                        autoSkip: true
                                    }
                                }
                            }
                        }
                    });

                    // Guardar referencia global al overview chart
                    window.overviewChart = overviewChart;

                    // Agregar funcionalidad de reset de zoom para overview chart
                    const resetOverviewZoomBtn = document.getElementById('resetOverviewZoomBtn');
                    if (resetOverviewZoomBtn) {
                        resetOverviewZoomBtn.addEventListener('click', function() {
                            overviewChart.resetZoom();
                        });
                    }
                }
            }

            const iterationNumbers = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.IterationNumbers ?? new List<int>()));
            const iterationEstimates = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.IterationEstimates ?? new List<double>()));
            const iterationErrors = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.IterationErrors ?? new List<double>()));
            const iterationRelativeErrors = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.IterationRelativeErrors ?? new List<double>()));
            const iterationResiduals = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.IterationResiduals ?? new List<double>()));

            if (iterationNumbers && iterationNumbers.length > 0) {
                const estimateCanvas = document.getElementById('iterationEstimateChart');
                if (estimateCanvas) {
                    const estimateCtx = estimateCanvas.getContext('2d');
                    new Chart(estimateCtx, {
                        type: 'line',
                        data: {
                            labels: iterationNumbers,
                            datasets: [{
                                label: 'Estimación de raíz',
                                data: iterationEstimates,
                                borderColor: 'rgb(255, 206, 86)',
                                backgroundColor: 'rgba(255, 206, 86, 0.2)',
                                borderWidth: 2,
                                tension: 0.15,
                                pointRadius: 3
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: { legend: { display: true, position: 'top' } },
                            scales: {
                                x: { title: { display: true, text: 'Iteración n' } },
                                y: { title: { display: true, text: 'x_n estimado' } }
                            }
                        }
                    });
                }

                const errorCanvas = document.getElementById('iterationErrorChart');
                if (errorCanvas) {
                    const errorCtx = errorCanvas.getContext('2d');
                    new Chart(errorCtx, {
                        type: 'line',
                        data: {
                            labels: iterationNumbers,
                            datasets: [
                                {
                                    label: 'Error absoluto',
                                    data: iterationErrors,
                                    borderColor: 'rgb(255, 99, 132)',
                                    backgroundColor: 'rgba(255, 99, 132, 0.2)',
                                    borderWidth: 2,
                                    tension: 0.15,
                                    pointRadius: 2
                                },
                                {
                                    label: 'Error relativo',
                                    data: iterationRelativeErrors,
                                    borderColor: 'rgb(255, 205, 86)',
                                    backgroundColor: 'rgba(255, 205, 86, 0.2)',
                                    borderWidth: 2,
                                    tension: 0.15,
                                    pointRadius: 2
                                },
                                {
                                    label: 'Residual',
                                    data: iterationResiduals,
                                    borderColor: 'rgb(54, 162, 235)',
                                    backgroundColor: 'rgba(54, 162, 235, 0.2)',
                                    borderWidth: 2,
                                    tension: 0.15,
                                    pointRadius: 2
                                }
                            ]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: { legend: { display: true, position: 'top' } },
                            scales: {
                                x: { title: { display: true, text: 'Iteración n' } },
                                y: {
                                    type: 'logarithmic',
                                    title: { display: true, text: 'Magnitud (log)' }
                                }
                            }
                        }
                    });
                }
            }
        });
    </script>
</div>
