@page
@model MonteCarloModel
@{
    ViewData["Title"] = "Integracion Monte Carlo";
}

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-zoom@2.1.0/dist/chartjs-plugin-zoom.min.js"></script>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css">
<script src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.js"></script>

<script>
document.addEventListener('DOMContentLoaded', function () {
    const input = document.getElementById('Function');
    const kb = document.getElementById('mathKeyboard');
    if (!kb || !input) return;
    kb.addEventListener('click', function (e) {
        const btn = e.target.closest('button[data-insert]');
        if (!btn) return;
        const val = btn.dataset.insert;
        const start = input.selectionStart ?? input.value.length;
        const end   = input.selectionEnd   ?? input.value.length;
        if (val === '__backspace__') {
            if (start === end && start > 0) {
                input.value = input.value.slice(0, start - 1) + input.value.slice(end);
                input.setSelectionRange(start - 1, start - 1);
            } else {
                input.value = input.value.slice(0, start) + input.value.slice(end);
                input.setSelectionRange(start, start);
            }
        } else {
            input.value = input.value.slice(0, start) + val + input.value.slice(end);
            const cursor = start + val.length;
            input.setSelectionRange(cursor, cursor);
        }
        input.focus();
    });

    // When user types in one confidence field, clear the other
    const clField = document.getElementById('ConfidenceLevel');
    const zField  = document.getElementById('ZCriticalInput');
    if (clField && zField) {
        clField.addEventListener('input', function () {
            if (clField.value.trim() !== '') zField.value = '';
        });
        zField.addEventListener('input', function () {
            if (zField.value.trim() !== '') clField.value = '';
        });
    }

    // When user types in N, clear MaxError and vice versa
    const nField = document.getElementById('SamplesCount');
    const eField = document.getElementById('MaxError');
    if (nField && eField) {
        nField.addEventListener('input', function () {
            if (nField.value.trim() !== '') eField.value = '';
        });
        eField.addEventListener('input', function () {
            if (eField.value.trim() !== '') nField.value = '';
        });
    }
});
</script>

<div class="container mt-4">
    <h1 class="mb-3">Integracion numerica con Monte Carlo</h1>
    <p>Estima la integral definida muestreando puntos aleatorios uniformes en el intervalo [a, b].</p>

    <form method="post" class="mb-4">
        <div class="card mb-3">
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-8">
                        <label class="form-label" for="Function">f(x)</label>
                        <input class="form-control" id="Function" name="Function" value="@Model.Function" required autocomplete="off" />
                        <div class="form-text mb-2">Soporta expresiones como <code>sin(x)</code>, <code>x*y + z^2</code>, <code>exp(-(x^2+y^2))</code>.</div>
                        <div id="mathKeyboard" class="d-flex flex-wrap gap-1">
                            @{
                                var keys = new[] {
                                    ("x", "x"), ("y", "y"), ("z", "z"),
                                    ("+", "+"), ("-", "-"), ("×", "*"), ("÷", "/"), ("^", "^"), ("(", "("), (")", ")"), (".", "."),
                                    ("π", "pi"), ("e", "e"),
                                    ("sin(", "sin("), ("cos(", "cos("), ("tan(", "tan("),
                                    ("arcsin(", "arcsin("), ("arccos(", "arccos("), ("arctan(", "arctan("),
                                    ("sinh(", "sinh("), ("cosh(", "cosh("), ("tanh(", "tanh("),
                                    ("√(", "sqrt("), ("exp(", "exp("), ("ln(", "ln("), ("log(", "log("),
                                    ("⌫", "__backspace__")
                                };
                            }
                            @foreach (var (label, value) in keys)
                            {
                                <button type="button"
                                        class="btn btn-sm btn-outline-secondary font-monospace"
                                        data-insert="@value"
                                        style="min-width:3rem;">@label</button>
                            }
                        </div>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label" for="Dimensions">Dimension</label>
                        <select class="form-select" id="Dimensions" name="Dimensions">
                            <option value="1" selected="@(Model.Dimensions == 1)">1D (integral simple)</option>
                            <option value="2" selected="@(Model.Dimensions == 2)">2D (integral doble)</option>
                            <option value="3" selected="@(Model.Dimensions == 3)">3D (integral triple)</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label" for="A">ax</label>
                        <input class="form-control" id="A" name="A" value="@Model.A" required placeholder="0" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label" for="B">bx</label>
                        <input class="form-control" id="B" name="B" value="@Model.B" required placeholder="pi" />
                    </div>
                    <div class="col-12">
                        <span class="form-text">Los limites aceptan expresiones como <code>pi</code>, <code>2*pi</code>, <code>pi/4</code>, <code>e</code>.</span>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label" for="AY">ay</label>
                        <input class="form-control" id="AY" name="AY" value="@Model.AY" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label" for="BY">by</label>
                        <input class="form-control" id="BY" name="BY" value="@Model.BY" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label" for="AZ">az</label>
                        <input class="form-control" id="AZ" name="AZ" value="@Model.AZ" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label" for="BZ">bz</label>
                        <input class="form-control" id="BZ" name="BZ" value="@Model.BZ" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label" for="SamplesCount">Muestras (N)</label>
                        <input class="form-control" id="SamplesCount" name="SamplesCount"
                               value="@(Model.SamplesCount.HasValue ? Model.SamplesCount.Value.ToString() : string.Empty)"
                               placeholder="5000" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label" for="MaxError">Error maximo</label>
                        <input class="form-control" id="MaxError" name="MaxError"
                               value="@(Model.MaxError.HasValue ? Model.MaxError.Value.ToString(System.Globalization.CultureInfo.InvariantCulture) : string.Empty)"
                               placeholder="0.01" />
                        <span class="form-text">Completa uno; el otro se calcula.</span>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label" for="ConfidenceLevel">Nivel de confianza (%)</label>
                        <input class="form-control" id="ConfidenceLevel" name="ConfidenceLevel"
                               value="@(Model.ConfidenceLevel.HasValue ? Model.ConfidenceLevel.Value.ToString(System.Globalization.CultureInfo.InvariantCulture) : string.Empty)"
                               placeholder="95" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label" for="ZCriticalInput">z critico</label>
                        <input class="form-control" id="ZCriticalInput" name="ZCriticalInput"
                               value="@(Model.ZCriticalInput.HasValue ? Model.ZCriticalInput.Value.ToString(System.Globalization.CultureInfo.InvariantCulture) : string.Empty)"
                               placeholder="1.96" />
                        <span class="form-text">Completa uno; el otro se calcula.</span>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label" for="Seed">Semilla (opcional)</label>
                        <input class="form-control" id="Seed" name="Seed" value="@(Model.Seed.HasValue ? Model.Seed.Value.ToString() : string.Empty)" />
                    </div>
                    <div class="col-md-3 d-flex align-items-end">
                        <button type="submit" class="btn btn-primary w-100">Estimar integral</button>
                    </div>
                </div>
            </div>
        </div>
    </form>

    @if (!string.IsNullOrEmpty(Model.ResultMessage))
    {
        <div class="alert @(Model.HasResult ? "alert-success" : "alert-danger")">
            <div>@Model.ResultMessage</div>
            @if (Model.HasResult)
            {
                <div class="mt-2">@Model.SummaryMessage</div>
            }
        </div>
    }

    @if (Model.HasResult)
    {
        <div class="card mb-4">
            <div class="card-body">
                <h5 class="card-title">Funcion ingresada</h5>
                <div id="functionLatex" class="border rounded p-2"></div>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-body">
                <h5 class="card-title">Resumen</h5>
                <div><strong>Dimension:</strong> @Model.Dimensions D</div>
                <div><strong>Volumen del dominio:</strong> @Model.DomainVolume.ToString("0.0000000000")</div>
                <div><strong>Integral aproximada:</strong> @Model.Approximation.ToString("0.0000000000")</div>
                <div><strong>Media muestral E[f(X)]:</strong> @Model.MeanValue.ToString("0.0000000000")</div>
                <div><strong>Desviacion estandar muestral de f(X):</strong> @Model.StandardDeviation.ToString("0.0000000000")</div>
                <div><strong>Error estandar estimado:</strong> @Model.StandardError.ToString("0.0000000000")</div>
                <div><strong>Muestras utilizadas:</strong> @Model.EffectiveSamplesUsed</div>
                @if (Model.MaxError.HasValue)
                {
                    <div>
                        <strong>Error maximo solicitado:</strong> @Model.MaxError.Value.ToString("0.##########")
                        @if (Model.ToleranceMet)
                        {
                            <span class="badge bg-success ms-2">Tolerancia alcanzada</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark ms-2">No alcanzada</span>
                        }
                    </div>
                    @if (Model.EstimatedNForTolerance.HasValue)
                    {
                        <div><strong>N estimado para tolerancia:</strong> ~@Model.EstimatedNForTolerance.Value.ToString("N0")</div>
                    }
                }
                <div><strong>IC @Model.ConfidenceLevel?.ToString("0.##")%:</strong> [@Model.ConfidenceLower.ToString("0.0000000000"),&nbsp;@Model.ConfidenceUpper.ToString("0.0000000000")]&nbsp;<span class="text-muted small">(z = @Model.ZCritical.ToString("0.0000000000"))</span></div>
                <div><strong>Semilla usada:</strong> @Model.EffectiveSeed</div>
            </div>
        </div>

        @if (Model.Dimensions == 1)
        {
            <div class="card mb-4">
                <div class="card-body">
                    <h5 class="card-title">Funcion y puntos dentro/fuera del area</h5>
                    <div style="position:relative;height:420px;">
                        <canvas id="monteCarloChart"></canvas>
                    </div>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-body">
                    <h5 class="card-title">Convergencia del estimador</h5>
                    <p class="text-muted small mb-2">Estimacion parcial de la integral a medida que se acumulan muestras (primeras @Model.Samples.Count). La linea punteada es el resultado final.</p>
                    <div style="position:relative;height:300px;">
                        <canvas id="convergenceChart"></canvas>
                    </div>
                </div>
            </div>
        }

        <div class="card mb-4">
            <div class="card-body">
                <h5 class="card-title">Primeras muestras</h5>
                <div class="table-responsive">
                    <table class="table table-striped table-bordered mb-0">
                        <thead>
                            <tr>
                                <th>i</th>
                                <th>x_i</th>
                                @if (Model.Dimensions >= 2)
                                {
                                    <th>y_i</th>
                                }
                                @if (Model.Dimensions == 3)
                                {
                                    <th>z_i</th>
                                }
                                <th>f(x_i)</th>
                                <th>Media parcial</th>
                                <th>Integral parcial</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var sample in Model.Samples)
                            {
                                <tr>
                                    <td>@sample.Index</td>
                                    <td>@sample.X.ToString("F8")</td>
                                    @if (Model.Dimensions >= 2)
                                    {
                                        <td>@(sample.Y?.ToString("F8") ?? "-")</td>
                                    }
                                    @if (Model.Dimensions == 3)
                                    {
                                        <td>@(sample.Z?.ToString("F8") ?? "-")</td>
                                    }
                                    <td>@sample.FX.ToString("F8")</td>
                                    <td>@sample.PartialMean.ToString("F8")</td>
                                    <td>@sample.PartialIntegralEstimate.ToString("F8")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@if (Model.HasResult)
{
    <script>
        (function () {
            const fnLatex = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.FunctionLatex));
            const fnContainer = document.getElementById('functionLatex');
            if (fnContainer) {
                try { katex.render(fnLatex, fnContainer, { throwOnError: false }); }
                catch { fnContainer.textContent = fnLatex; }
            }
        })();

        if (@Model.Dimensions === 1) {
        (function () {
            const convIndices = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Samples.Select(s => s.Index).ToList()));
            const convEstimates = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Samples.Select(s => s.PartialIntegralEstimate).ToList()));
            const finalApprox = @Model.Approximation.ToString(System.Globalization.CultureInfo.InvariantCulture);

            const convData = convIndices.map((idx, i) => ({ x: idx, y: convEstimates[i] }));
            const finalLineData = convIndices.length > 0
                ? [{ x: convIndices[0], y: finalApprox }, { x: convIndices[convIndices.length - 1], y: finalApprox }]
                : [];

            new Chart(document.getElementById('convergenceChart').getContext('2d'), {
                type: 'line',
                data: {
                    datasets: [
                        {
                            label: 'Estimacion parcial',
                            data: convData,
                            borderColor: '#4fc3f7',
                            backgroundColor: 'transparent',
                            pointRadius: 0,
                            borderWidth: 1.5,
                            tension: 0
                        },
                        {
                            label: 'Resultado final',
                            data: finalLineData,
                            borderColor: '#ffcc80',
                            backgroundColor: 'transparent',
                            pointRadius: 0,
                            borderWidth: 1.5,
                            borderDash: [6, 4],
                            tension: 0
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    animation: false,
                    scales: {
                        x: { type: 'linear', title: { display: true, text: 'Muestra i', font: { size: 13 } } },
                        y: { title: { display: true, text: 'Integral estimada', font: { size: 13 } } }
                    },
                    plugins: { legend: { display: true } }
                }
            });
        })();

        (function () {
            const xValues = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ChartXValues));
            const yValues = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ChartYValues));
            const insideX = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.InsideAreaXValues));
            const insideY = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.InsideAreaYValues));
            const outsideX = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.OutsideAreaXValues));
            const outsideY = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.OutsideAreaYValues));

            const curveData = xValues.map((x, i) => ({ x, y: yValues[i] }));
            const insideData = insideX.map((x, i) => ({ x, y: insideY[i] }));
            const outsideData = outsideX.map((x, i) => ({ x, y: outsideY[i] }));

            const zoomPlugin = {
                zoom: { wheel: { enabled: true }, pinch: { enabled: true }, mode: 'xy' },
                pan: { enabled: true, modifierKey: 'ctrl', mode: 'xy' }
            };

            const axisGridConfig = {
                drawBorder: true,
                color: function(context) {
                    return context.tick.value === 0 ? 'rgba(200, 200, 200, 0.8)' : 'rgba(100, 100, 100, 0.2)';
                },
                lineWidth: function(context) {
                    return context.tick.value === 0 ? 2.5 : 1;
                }
            };

            new Chart(document.getElementById('monteCarloChart').getContext('2d'), {
                type: 'line',
                data: {
                    datasets: [
                        {
                            label: 'f(x)',
                            data: curveData,
                            borderColor: '#4fc3f7',
                            backgroundColor: '#4fc3f7',
                            pointRadius: 0,
                            borderWidth: 2,
                            tension: 0
                        },
                        {
                            label: 'Dentro del area',
                            data: insideData,
                            type: 'scatter',
                            borderColor: '#66bb6a',
                            backgroundColor: 'rgba(102, 187, 106, 0.65)',
                            pointRadius: 2.5,
                            showLine: false
                        },
                        {
                            label: 'Fuera del area',
                            data: outsideData,
                            type: 'scatter',
                            borderColor: '#ef5350',
                            backgroundColor: 'rgba(239, 83, 80, 0.65)',
                            pointRadius: 2.5,
                            showLine: false
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    animation: false,
                    scales: {
                        x: { type: 'linear', position: 'bottom', title: { display: true, text: 'x', font: { size: 14 } }, grid: axisGridConfig, ticks: { padding: 10, autoSkip: true, maxRotation: 0 } },
                        y: { position: 'left', title: { display: true, text: 'f(x)', font: { size: 14 } }, grid: axisGridConfig, ticks: { padding: 10, autoSkip: true } }
                    },
                    plugins: { zoom: zoomPlugin }
                }
            });
        })();
        }
    </script>
}
