@page
@model NewtonCotesModel
@{
	ViewData["Title"] = "Integracion de Newton-Cotes";
}

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-zoom@2.1.0/dist/chartjs-plugin-zoom.min.js"></script>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css">
<script src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.js"></script>

<div class="container mt-4">
	<h1 class="mb-3">Integracion numerica con Newton-Cotes</h1>
	<p>Calcula integrales definidas usando reglas compuestas del trapecio, Simpson 1/3 y Simpson 3/8.</p>

	<form method="post" class="mb-4">
		<div class="card mb-3">
			<div class="card-body">
				<div class="row g-3">
					<div class="col-md-4">
						<label class="form-label" for="SelectedRule">Regla</label>
						<select class="form-select" id="SelectedRule" name="SelectedRule">
							<option value="trapezoidal" selected="@(Model.SelectedRule == "trapezoidal")">Trapecio compuesto</option>
							<option value="simpson-13" selected="@(Model.SelectedRule == "simpson-13")">Simpson 1/3 compuesto</option>
							<option value="simpson-38" selected="@(Model.SelectedRule == "simpson-38")">Simpson 3/8 compuesto</option>
						</select>
					</div>
					<div class="col-md-8">
						<label class="form-label" for="Function">f(x)</label>
						<input class="form-control" id="Function" name="Function" value="@Model.Function" required />
						<div class="form-text">Soporta expresiones como <code>sin(x)</code>, <code>exp(x)</code>, <code>x^2 + 1</code>.</div>
					</div>
					<div class="col-md-3">
						<label class="form-label" for="A">a</label>
						<input class="form-control" id="A" name="A" value="@Model.A" required />
					</div>
					<div class="col-md-3">
						<label class="form-label" for="B">b</label>
						<input class="form-control" id="B" name="B" value="@Model.B" required />
					</div>
					<div class="col-md-3">
						<label class="form-label" for="N">n</label>
						<input class="form-control" id="N" name="N" value="@Model.N" required />
					</div>
					<div class="col-md-3 d-flex align-items-end">
						<button type="submit" class="btn btn-primary w-100">Integrar</button>
					</div>
				</div>
				<div class="form-text mt-3">Restricciones: trapecio n &gt;= 1, Simpson 1/3 n par, Simpson 3/8 n multiplo de 3.</div>
				<div class="form-text">Los límites aceptan expresiones como <code>pi</code>, <code>2*pi</code>, <code>e</code>, <code>ln(2)</code>, <code>sqrt(3)</code>.</div>
			</div>
		</div>
	</form>

	@if (!string.IsNullOrEmpty(Model.ResultMessage))
	{
		<div class="alert @(Model.HasResult ? "alert-success" : "alert-danger")">
			<div>@Model.ResultMessage</div>
			@if (Model.HasResult)
			{
				<div class="mt-2">@Model.SummaryMessage</div>
			}
		</div>
	}

	@if (Model.HasResult)
	{
		<div class="card mb-4">
			<div class="card-body">
				<h5 class="card-title">Resumen</h5>
				<div><strong>Regla:</strong> @Model.RuleDisplayName</div>
				<div><strong>Integral aproximada:</strong> @Model.Approximation.ToString("0.0000000000")</div>
				<div><strong>Paso h:</strong> @Model.StepSize.ToString("0.000000")</div>
				<div><strong>Subintervalos:</strong> @Model.N</div>
			</div>
		</div>

		<div class="card mb-4">
			<div class="card-body">
				<h5 class="card-title">Formula de Newton-Cotes</h5>
				<div id="formulaLatex" class="border rounded p-2 mb-3"></div>
				<div class="mb-2"><strong>Cota teorica del error</strong></div>
				<div id="errorLatex" class="border rounded p-2"></div>
			</div>
		</div>

		<div class="card mb-4">
			<div class="card-body">
				<h5 class="card-title">Funcion y area integrada en [a, b]</h5>
				<div style="position:relative;height:420px;">
					<canvas id="integrationChart"></canvas>
				</div>
			</div>
		</div>

		<div class="card mb-4">
			<div class="card-body">
				<h5 class="card-title">Contribucion ponderada por nodo</h5>
				<p class="text-muted small mb-2">Coeficiente &times; f(x<sub>i</sub>) para cada nodo. El area total es proporcional a la suma de estas barras.</p>
				<div style="position:relative;height:300px;">
					<canvas id="weightsChart"></canvas>
				</div>
			</div>
		</div>

		<div class="card mb-4">
			<div class="card-body">
				<h5 class="card-title">Tabla de nodos y pesos</h5>
				<div class="table-responsive">
					<table class="table table-striped table-bordered mb-0">
						<thead>
							<tr>
								<th>i</th>
								<th>x_i</th>
								<th>f(x_i)</th>
								<th>Coef.</th>
								<th>Coef. * f(x_i)</th>
								<th>Suma parcial</th>
							</tr>
						</thead>
						<tbody>
							@foreach (var node in Model.Nodes)
							{
								<tr>
									<td>@node.Index</td>
									<td>@node.X.ToString("F8")</td>
									<td>@node.FX.ToString("F8")</td>
									<td>@node.Coefficient</td>
									<td>@node.WeightedValue.ToString("F8")</td>
									<td>@node.PartialWeightedSum.ToString("F8")</td>
								</tr>
							}
						</tbody>
					</table>
				</div>
			</div>
		</div>
	}
</div>

@if (Model.HasResult)
{
	<script>
		(function () {
			const formula = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.FormulaLatex));
			const errorFormula = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ErrorBoundLatex));
			const formulaContainer = document.getElementById('formulaLatex');
			const errorContainer = document.getElementById('errorLatex');

			if (formulaContainer) {
				try {
					katex.render(formula, formulaContainer, { throwOnError: false });
				} catch {
					formulaContainer.textContent = formula;
				}
			}

			if (errorContainer) {
				try {
					katex.render(errorFormula, errorContainer, { throwOnError: false });
				} catch {
					errorContainer.textContent = errorFormula;
				}
			}
		})();

		(function () {
			const xValues = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ChartXValues));
			const yValues = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ChartYValues));
			const nodeX = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.NodeChartXValues));
			const nodeY = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.NodeChartYValues));
			const nodeWeights = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Nodes.Select(n => n.WeightedValue).ToList()));
			const nodeLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Nodes.Select(n => n.X.ToString("F4")).ToList()));

			const curveData = xValues.map((x, i) => ({ x, y: yValues[i] }));
			const nodeData = nodeX.map((x, i) => ({ x, y: nodeY[i] }));

			// Vertical panel stems
			const stemData = [];
			for (let i = 0; i < nodeX.length; i++) {
				stemData.push({ x: nodeX[i], y: 0 });
				stemData.push({ x: nodeX[i], y: nodeY[i] });
				stemData.push(null);
			}

			const zoomPlugin = {
				zoom: { wheel: { enabled: true }, pinch: { enabled: true }, mode: 'xy' },
				pan: { enabled: true, modifierKey: 'ctrl', mode: 'xy' }
			};

			const axisGridConfig = {
				drawBorder: true,
				color: function(context) {
					return context.tick.value === 0 ? 'rgba(200, 200, 200, 0.8)' : 'rgba(100, 100, 100, 0.2)';
				},
				lineWidth: function(context) {
					return context.tick.value === 0 ? 2.5 : 1;
				}
			};

			new Chart(document.getElementById('integrationChart').getContext('2d'), {
				type: 'line',
				data: {
					datasets: [
						{
							label: 'Area integrada',
							data: curveData,
							borderColor: 'rgba(79, 195, 247, 0)',
							backgroundColor: 'rgba(79, 195, 247, 0.20)',
							pointRadius: 0,
							fill: 'origin',
							tension: 0
						},
						{
							label: 'f(x)',
							data: curveData,
							borderColor: '#4fc3f7',
							backgroundColor: '#4fc3f7',
							pointRadius: 0,
							borderWidth: 2,
							tension: 0
						},
						{
							label: 'Nodos de integracion',
							data: nodeData,
							type: 'scatter',
							borderColor: '#ffcc80',
							backgroundColor: '#ffcc80',
							pointRadius: 4,
							showLine: false
						}
					]
				},
				options: {
					responsive: true,
					maintainAspectRatio: false,
					animation: false,
					scales: {
						x: { type: 'linear', position: 'bottom', title: { display: true, text: 'x', font: { size: 14 } }, grid: axisGridConfig, ticks: { padding: 10, autoSkip: true, maxRotation: 0 } },
						y: { position: 'left', title: { display: true, text: 'f(x)', font: { size: 14 } }, grid: axisGridConfig, ticks: { padding: 10, autoSkip: true } }
					},
					plugins: { zoom: zoomPlugin }
				}
			});
		})();

		(function () {
			const nodeWeights2 = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Nodes.Select(n => n.WeightedValue).ToList()));
			const nodeLabels2 = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Nodes.Select(n => n.X.ToString("F4")).ToList()));

			const barColors = nodeWeights2.map(v => v >= 0 ? 'rgba(79, 195, 247, 0.75)' : 'rgba(239, 83, 80, 0.75)');
			const borderColors = nodeWeights2.map(v => v >= 0 ? '#4fc3f7' : '#ef5350');

			new Chart(document.getElementById('weightsChart').getContext('2d'), {
				type: 'bar',
				data: {
					labels: nodeLabels2,
					datasets: [{
						label: 'Coef. × f(xᵢ)',
						data: nodeWeights2,
						backgroundColor: barColors,
						borderColor: borderColors,
						borderWidth: 1
					}]
				},
				options: {
					responsive: true,
					maintainAspectRatio: false,
					animation: false,
					scales: {
						x: { title: { display: true, text: 'xᵢ', font: { size: 13 } }, ticks: { maxRotation: 45 } },
						y: { title: { display: true, text: 'Coef. × f(xᵢ)', font: { size: 13 } } }
					},
					plugins: { legend: { display: false } }
				}
			});
		})();
	</script>
}